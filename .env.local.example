# URL site (metadata Open Graph / Twitter) — production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
# Lấy từ: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Giá in (VNĐ / 1 trang) – dùng tính tổng tiền và hiển thị "Tổng cộng"
NEXT_PUBLIC_PRICE_PER_PAGE=500

# Nghiệp vụ hiển thị (tùy chọn — xem lib/config/business.ts)
# Địa chỉ lấy hàng (một dòng) — trang thanh toán khi chọn tự đến lấy
# NEXT_PUBLIC_PICKUP_ADDRESS=454 Bình Giã, phường Tam Thắng, TP. Hồ Chí Minh
# Ngưỡng freeship (VNĐ) — đồng bộ form gợi ý và calculateGrandTotal
# NEXT_PUBLIC_FREESHIP_THRESHOLD_VND=200000

# VietQR – bắt buộc STK thật; mã NH đúng theo https://api.vietqr.io/v2/banks (BIN / shortName).
# Sai hoặc để số mẫu → img.vietqr.io trả lỗi → ảnh QR trên trang thanh toán không hiển thị.
NEXT_PUBLIC_VIETQR_BANK_ID=MB
NEXT_PUBLIC_VIETQR_ACCOUNT_NO=your-real-account-number

# Webhook SePay – xác nhận thanh toán tự động
# SECRET KEY (dùng để xác thực webhook) – bắt buộc cho /api/webhook/sepay
WEBHOOK_SEPAY_API_KEY=your-sepay-secret-key
# MERCHANT ID – chỉ cần khi gọi API SePay (tra cứu, tạo đơn...); nhận webhook thì không dùng
# SEPAY_MERCHANT_ID=SP-TEST-XXXXXX

# Supabase Service Role Key (chỉ dùng trên server: webhook, cron)
# Lấy tại: Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin đăng nhập: Authentication → Users → chọn user → App metadata JSON: {"role":"admin"}
